PORT=5002
MONGODB_URI=mongodb://127.0.0.1:27017/hsms
JWT_SECRET=change-me-in-production
SESSION_IDLE_TIMEOUT_MS=1800000
SEED_ADMIN_EMAIL=admin@hsms.local
SEED_ADMIN_PASSWORD=change-me

# --- Phase 8 / production hardening (optional) ---
# JWT expiry is derived from SESSION_IDLE_TIMEOUT_MS (see src/lib/jwt.js).
# Behind nginx/Caddy with HTTPS: set so rate limiting sees client IPs correctly.
# TRUST_PROXY=1
# Rate limits (see src/middleware/rateLimits.js)
# RATE_LIMIT_LOGIN_WINDOW_MS=900000
# RATE_LIMIT_LOGIN_MAX=40
# RATE_LIMIT_SOS_WINDOW_MS=3600000
# RATE_LIMIT_SOS_MAX=24
# Smoke script (npm run smoke): optional login verification
# SMOKE_BASE_URL=http://127.0.0.1:5001
# SMOKE_EMAIL=
# SMOKE_PASSWORD=
# SMOKE_TIMEOUT_MS=8000
